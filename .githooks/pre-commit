#!/usr/bin/env bash
set -euo pipefail

# Pre-commit hook: run formatting checks and unit tests before commit
# 1) run dotnet format verification on solution
# 2) run unit tests

SOLUTION_FILE="WeatherApp.sln"

echo "[pre-commit] Running dotnet format verification..."
dotnet format "$SOLUTION_FILE" --verify-no-changes

echo "[pre-commit] Running unit tests..."
dotnet test "$SOLUTION_FILE" --no-restore

echo "[pre-commit] All checks passed."
